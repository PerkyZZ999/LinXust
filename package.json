{
	"name": "linxust",
	"private": true,
	"version": "0.1.0",
	"description": "LinXust Electron + Rust napi-rs archiver",
	"main": "electron/main.cjs",
	"scripts": {
		"dev:frontend": "cd frontend && bun run dev",
		"build:frontend": "cd frontend && bun run build",
		"lint:frontend": "cd frontend && bun run lint",
		"format:frontend": "cd frontend && bun run format",
		"build:native": "cd native && bun run build",
		"verify:native-bridge": "bun electron/verify-native-bridge.cjs",
		"build": "bun run build:frontend && bun run build:native",
		"test:native": "cargo test --manifest-path native/Cargo.toml",
		"test": "bun run test:native",
		"electron": "electron ."
	},
	"dependencies": {
		"electron": "40.8.0"
	}
}
